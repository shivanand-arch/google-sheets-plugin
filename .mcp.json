{
  "mcpServers": {
    "google-sheets": {
      "command": "/usr/local/bin/node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/servers/server.js"
      ],
      "env": {
        "GOOGLE_CLIENT_ID": "${GOOGLE_SHEETS_CLIENT_ID}",
        "GOOGLE_CLIENT_SECRET": "${GOOGLE_SHEETS_CLIENT_SECRET}",
        "GOOGLE_REFRESH_TOKEN": "${GOOGLE_SHEETS_REFRESH_TOKEN}"
      }
    }
  }
}
